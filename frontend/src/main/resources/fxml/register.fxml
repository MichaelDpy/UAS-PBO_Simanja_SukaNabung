<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.simanja.controller.RegisterController"
            styleClass="root-dark"
            prefWidth="1100" prefHeight="760">

    <center>
        <HBox>

            <!-- LEFT PANEL: foto via inline style background-image -->
            <StackPane HBox.hgrow="ALWAYS">
                <ImageView preserveRatio="false" smooth="true"
                           fitWidth="${paneBackgroundRegister.width}"
                           fitHeight="${paneBackgroundRegister.height}">
                    <image>
                        <Image url="@../images/background.png"/>
                    </image>
                </ImageView>

                <Pane fx:id="paneBackgroundRegister" styleClass="auth-bg-overlay"/>

                <VBox alignment="CENTER_LEFT" style="-fx-padding: 0 48 0 48;">
                    <Region VBox.vgrow="ALWAYS"/>

                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 20 0;">
                        <ImageView fitWidth="30" fitHeight="30" preserveRatio="true" smooth="true">
                            <image><Image url="@../images/logo-simanja.png"/></image>
                        </ImageView>
                        <Label text="Simanja" styleClass="auth-brand-overlay"/>
                    </HBox>

                    <Label text="Pertumbuhan finansial dimulai dengan satu langkah kecil hari ini."
                           styleClass="auth-tagline-overlay" wrapText="true"
                           style="-fx-padding: 0 0 12 0;"/>

                    <Label text="Wujudkan impian finansialmu dengan pengelolaan anggaran yang cerdas, pelacakan otomatis, dan wawasan mendalam untuk masa depan yang lebih mapan."
                           styleClass="auth-desc-overlay" wrapText="true"
                           style="-fx-padding: 0 0 36 0;"/>

                    <HBox spacing="48">
                        <VBox spacing="4">
                            <Label text="10k+" styleClass="auth-stat-value"/>
                            <Label text="PENGGUNA AKTIF" styleClass="auth-stat-label"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="99%" styleClass="auth-stat-value"/>
                            <Label text="KEPUASAN LAYANAN" styleClass="auth-stat-label"/>
                        </VBox>
                    </HBox>

                    <Region VBox.vgrow="ALWAYS"/>
                </VBox>
            </StackPane>

            <!-- RIGHT PANEL: Form register -->
            <VBox styleClass="auth-right-panel" alignment="CENTER" spacing="0" prefWidth="580">
                <padding><Insets top="50" right="68" bottom="50" left="68"/></padding>

                <VBox spacing="8" style="-fx-padding: 0 0 28 0;">
                    <Label text="Mulai Kelola Keuanganmu" styleClass="form-title"/>
                    <Label text="Buat akun gratis dan ambil kendali penuh atas uangmu."
                           styleClass="form-subtitle" wrapText="true"/>
                </VBox>

                <VBox spacing="8" style="-fx-padding: 0 0 14 0;">
                    <Label text="Nama Lengkap" styleClass="field-label"/>
                    <HBox styleClass="input-field-wrapper" alignment="CENTER_LEFT" spacing="10">
                        <Label text="👤" styleClass="input-icon"/>
                        <TextField fx:id="txtNama" promptText="Masukkan nama lengkap Anda"
                                   styleClass="input-field-borderless" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <VBox spacing="8" style="-fx-padding: 0 0 14 0;">
                    <Label text="Email" styleClass="field-label"/>
                    <HBox styleClass="input-field-wrapper" alignment="CENTER_LEFT" spacing="10">
                        <Label text="✉" styleClass="input-icon"/>
                        <TextField fx:id="txtEmail" promptText="contoh@email.com"
                                   styleClass="input-field-borderless" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <VBox spacing="6" style="-fx-padding: 0 0 14 0;">
                    <Label text="Kata Sandi" styleClass="field-label"/>
                    <HBox styleClass="input-field-wrapper" alignment="CENTER_LEFT" spacing="10">
                        <Label text="🔒" styleClass="input-icon"/>
                        <StackPane alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="input-field-borderless" />
                            <TextField fx:id="txtPasswordVisible" promptText="••••••••" styleClass="input-field-borderless" visible="false" managed="false"/>
                        </StackPane>
                        <Label fx:id="lblTogglePassword" text="👁" styleClass="input-icon-action"/>
                    </HBox>
                    <Label text="Minimal 8 karakter" styleClass="form-hint"/>
                </VBox>

                <VBox spacing="8" style="-fx-padding: 0 0 8 0;">
                    <Label text="Konfirmasi Kata Sandi" styleClass="field-label"/>
                    <HBox styleClass="input-field-wrapper" alignment="CENTER_LEFT" spacing="10">
                        <Label text="🔒" styleClass="input-icon"/>
                        <StackPane alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <PasswordField fx:id="txtKonfirmPassword" promptText="••••••••" styleClass="input-field-borderless" />
                            <TextField fx:id="txtKonfirmPasswordVisible" promptText="••••••••" styleClass="input-field-borderless" visible="false" managed="false"/>
                        </StackPane>
                        <Label fx:id="lblToggleKonfirm" text="👁" styleClass="input-icon-action"/>
                    </HBox>
                </VBox>

                <Label fx:id="lblError"   styleClass="error-label"   wrapText="true"
                       managed="false" visible="false" style="-fx-padding: 0 0 10 0;"/>
                <Label fx:id="lblSuccess" styleClass="success-label" wrapText="true"
                       managed="false" visible="false" style="-fx-padding: 0 0 10 0;"/>

                <Button text="Daftar Akun" fx:id="btnDaftar" styleClass="btn-primary-full"
                        prefWidth="99999" onAction="#handleDaftar"
                        style="-fx-padding: 16 20 16 20; -fx-font-size: 15px;"/>

                <HBox alignment="CENTER" spacing="12" style="-fx-padding: 18 0 18 0;">
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                    <Label text="Atau" styleClass="divider-text"/>
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                </HBox>

                <HBox alignment="CENTER" spacing="4">
                    <Label text="Sudah punya akun?" styleClass="form-hint"/>
                    <Hyperlink text="Masuk di sini" fx:id="linkLogin"
                               styleClass="link-accent" onAction="#handleLogin"/>
                </HBox>

            </VBox>
        </HBox>
    </center>
</BorderPane>
